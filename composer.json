{
    "name": "jaydeep/laravel-time-machine",
    "description": "Inspect, profile and visualize every stage of the Laravel request lifecycle — from bootstrapping to response — with detailed execution timelines and performance insights.",
    "keywords": ["laravel", "profiler", "debug", "performance", "request-lifecycle", "timeline", "profiling", "diagnostics"],
    "license": "MIT",
    "authors": [
        {
            "name": "Jaydeep Gadhiya",
            "email": "jaydeepgadhiya5699@gmail.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Jaydeep\\LaravelTimeMachine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jaydeep\\LaravelTimeMachine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jaydeep\\LaravelTimeMachine\\TimeMachineServiceProvider"
            ],
            "aliases": {
                "TimeMachine": "Jaydeep\\LaravelTimeMachine\\Facades\\TimeMachine"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
